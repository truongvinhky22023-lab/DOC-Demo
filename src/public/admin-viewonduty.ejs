 <div class="container">
        <div class="group-function row">
            <div class="col-lg-6">
                <h3>Danh sách On-Duty Trực Tiếp</h3>
            </div>
            
            <p class="text mb-1">Hiển thị thời gian thực bằng cách nhấn F5 để xem những nhân sự nào đang trực tiếp nhấn
                On-Duty</p>
        </div>

    <div class="table-responsive box-employees text-center">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-warning">
                <tr>
                    <th>STT</th>
                    <th>ID</th>
                    <th>Tên Ingame</th>
                    <th>Chức vụ</th>
                    <th>Quân hàm</th>
                    <th>Ngày</th>
                    <th>Giờ bắt đầu</th>
                    <th>Trạng thái</th>
                    <th>Hoạt động Discord</th>
                    <th>Tác vụ</th>
                </tr>
            </thead>
            <tbody>
    <% 
    let stt = 1;
    // Lấy ngày hiện tại theo định dạng chuẩn thường dùng trong DB
    const now = new Date();
    const today = now.toLocaleDateString('en-US'); 

    users.forEach(user => {
        // Tìm bản ghi chưa có offTime (nghĩa là đang On-Duty)
        // Chúng ta nên ưu tiên kiểm tra bản ghi mới nhất trong mảng attendance
        const attendance = user.attendance || [];
        const currentDuty = attendance.find(a => !a.offTime); 

        if (currentDuty) { 
            const onTime = currentDuty.onTime?.split(' - ')[0] || '-';
            
            // Fix logic lấy timestamp để chạy Timer
            // Nếu có onTimeFull (ISO string) thì dùng, không thì lấy giờ hiện tại trừ đi một khoảng (để tránh lỗi NaN)
            let checkInUnix;
            if (currentDuty.onTimeFull) {
                checkInUnix = Math.floor(new Date(currentDuty.onTimeFull).getTime() / 1000);
            } else {
                // Fallback: Nếu không có timestamp chuẩn, coi như vừa mới vào ca
                checkInUnix = Math.floor(Date.now() / 1000);
            }
    %>
    <tr>
        <td><%= stt++ %></td>
        <td>#<%= user.id %></td>
        <td class="fw-bold text-primary"><%= user.displayName %></td>
        <td><%= user.position %></td>
        <td><%= user.rank || '' %></td>
        <td><%= currentDuty.date %></td>
        <td><%= onTime %></td>
        <td>
            <span class="badge bg-success shadow-sm">
                <i class="fa-solid fa-circle-dot fa-beat-flash me-1"></i> Đang On-Duty
            </span>
            <div class="text-secondary mt-1">
                <small class="fw-bold">
                    <i class="fa-regular fa-clock"></i> 
                    <span class="live-timer" data-checkin="<%= checkInUnix %>">00:00:00</span>
                </small>
            </div>
        </td>
        <td>
            <% if (user.discordStatus) { %>
                <small class="text-success"><%= user.discordStatus %></small>
            <% } else { %>
                <small class="text-muted italic">Không tìm thấy hoạt động</small>
            <% } %>
        </td>
            <td class="profile_function">
                <div class="d-flex gap-1 justify-content-center">
                    <button class="btn_xem_ho_so" data-bs-toggle="modal" data-bs-target="#profileModal"
                        data-name="<%= user.displayName %>" 
                        data-position="<%= user.position %>" 
                        data-rank="<%= user.rank || '' %>"
                        data-username="<%= user.username || '' %>" 
                        data-status="Đang On-Duty">
                        Hồ Sơ
                    </button>
                    <form action="/admin/toggle-off/<%= user.id %>" method="POST" class="d-inline force-checkout-form" data-name="<%= user.displayName %>">
                        <input type="hidden" name="_token" value="vLGXGqwmmqK024QBgbxva8TsFd6aY8zgxHP5gnc4" autocomplete="off">                                        <input type="hidden" name="_method" value="PUT">                                        <button type="submit" class="btn_ket_thuc_ca">
                                                <i class="fa-solid fa-triangle-exclamation"></i> Cảnh Báo
                                            </button>
                    </form>

                    <form action="/admin/delete-duty/<%= user.id %>" method="POST" class="d-inline force-checkout-form" data-name="<%= user.displayName %>">
                        <button type="submit" class="btn btn-danger btn-sm btn_xoa_ca" title="Xóa ca làm việc">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                                    
                    </form>
                    
                </div>
            </td>
        </tr>
        <% } }) %>

    <% if (stt === 1) { %>
    <tr>
        <td colspan="10" class="text-center py-5">
            <img src="https://cdn-icons-png.flaticon.com/512/4076/4076432.png" width="80" class="opacity-25 mb-3">
            <p class="text-muted">Hiện không có nhân viên nào đang On-Duty</p>
        </td>
    </tr>
    <% } %>
</tbody>
        </table>
    </div>
</div>

<!-- Modal Hồ Sơ -->
<div class="modal fade" id="profileModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Hồ sơ người dùng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong>Tên Ingame:</strong> <span id="modalName"></span></p>
                <p><strong>Chức vụ:</strong> <span id="modalPosition"></span></p>
                <p><strong>Quân hàm:</strong> <span id="modalRank"></span></p>
                <p><strong>Tài khoản:</strong> <span id="modalUsername"></span></p>
                <p><strong>Trạng thái:</strong> <span id="modalStatus"></span></p>
            </div>
        </div>
    </div>
</div>

<!-- Modal Lịch Sử (giữ nguyên từ code cũ) -->
<!-- Bạn có thể giữ nguyên phần modal history cũ ở đây -->

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://www.lssdhrtime.com/assets/bootstrap-5.3.7-dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
// Live timer
document.addEventListener("DOMContentLoaded", () => {
    function format(sec) {
        const h = String(Math.floor(sec / 3600)).padStart(2, '0');
        const m = String(Math.floor((sec % 3600) / 60)).padStart(2, '0');
        const s = String(sec % 60).padStart(2, '0');
        return `${h}:${m}:${s}`;
    }
    function updateTimers() {
        const now = Math.floor(Date.now() / 1000);
        document.querySelectorAll('.live-timer').forEach(el => {
            const checkIn = Number(el.dataset.checkin);
            const elapsed = now - checkIn;
            el.textContent = format(elapsed > 0 ? elapsed : 0);
        });
    }
    setInterval(updateTimers, 1000);
    updateTimers();
});

// SweetAlert confirm cho force checkout & delete
document.querySelectorAll('.force-checkout-form').forEach(form => {
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        const name = this.dataset.name;
        const isDelete = this.querySelector('.btn_xoa_ca') !== null;
        Swal.fire({
            title: 'Xác nhận?',
            text: isDelete ? `Onduty của ${name} sẽ bị xóa và không tính lương!` : `Kết thúc ca của ${name}?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Có',
            cancelButtonText: 'Hủy'
        }).then(result => {
            if (result.isConfirmed) this.submit();
        });
    });
});

// Modal hồ sơ
const profileModal = document.getElementById('profileModal');
profileModal.addEventListener('show.bs.modal', event => {
    const button = event.relatedTarget;
    document.getElementById('modalName').textContent = button.dataset.name;
    document.getElementById('modalPosition').textContent = button.dataset.position;
    document.getElementById('modalRank').textContent = button.dataset.rank;
    document.getElementById('modalUsername').textContent = button.dataset.username;
    document.getElementById('modalStatus').textContent = button.dataset.status;
});
    
// Giữ chức năng openHistory và toggleDuty cũ nếu cần
// Auto reload
setInterval(() => {
    if (!profileModal.classList.contains('show')) location.reload();
}, 8000);
</script>
<div class="modal fade" id="salaryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fa-solid fa-calculator me-2"></i>Thống kê lương: <span id="salaryTargetName">...</span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3 text-center">
                    <div class="col-md-4">
                        <div class="card bg-light p-2">
                            <small>Tổng giờ tháng này</small>
                            <h4 id="totalHours">0h</h4>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-light p-2">
                            <small>Hệ số lương</small>
                            <h4 id="ratePerHour">0$/h</h4>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card bg-primary text-white p-2">
                            <small>Tổng lương dự kiến</small>
                            <h4 id="totalSalary">0$</h4>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-sm table-bordered align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Ngày</th>
                                <th>Bắt đầu</th>
                                <th>Kết thúc</th>
                                <th>Tổng phút</th>
                                <th>Thành tiền</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody id="salaryDetailBody">
                            </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>