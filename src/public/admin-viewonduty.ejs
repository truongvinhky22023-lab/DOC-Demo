            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="/home"><i class="fa-solid fa-house"></i> Trang Chủ</a></li>
                <li class="nav-item border bg-warning px-2 mx-1">
                    <a class="nav-link text-white active-link" href="/admin-panel">On-Duty Trực Tiếp <span class="rounded-circle bg-danger text-white" style="padding: 3px 6px;font-size: 13px;"><%= stats.onDuty %></span></a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Quản Lý</a>
                    <ul class="dropdown-menu">
                        <li><a class="nav-link" href="/admin"><i class="fa-solid fa-users"></i> Nhân Sự</a></li>
                        <li><a class="nav-link" href="/payroll"><i class="fa-solid fa-sack-dollar"></i> Công/Lương</a></li>
                        <li><a class="nav-link active-link" href="/admin-panel">Onduty LIVE</a></li>
                    </ul>
                </li>
