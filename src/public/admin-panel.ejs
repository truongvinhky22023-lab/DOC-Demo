<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <link rel="icon" type="image/x-icon" href="/images/Logo_DOC.png">
  <title>Lương</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <style>
    body { background: #f1f5f9; font-family: 'Segoe UI', sans-serif; }
    .modal { display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.85); z-index: 100; align-items: center; justify-content: center; backdrop-filter: blur(8px); }
    .modal.active { display: flex; }
    .custom-scroll::-webkit-scrollbar { width: 6px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    tr { transition: all 0.2s ease; }
  </style>
</head>
<body class="p-4 md:p-8">

  <div class="max-w-7xl mx-auto">
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center mb-8 gap-6">
        <div>
            <h1 class="text-4xl font-black text-slate-900 flex items-center gap-4">
              <div class="p-3 bg-blue-600 rounded-2xl text-white shadow-xl rotate-3"><i data-lucide="shield-check"></i></div>
             Thông Tin Chấm Công Và Tiền Lương
            </h1>
        </div>
        
        <div class="flex flex-wrap gap-3">
            <button onclick="openPreviousMonth()" class="flex items-center gap-2 bg-slate-800 hover:bg-slate-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg transition-all active:scale-95">
                <i data-lucide="history"></i> Lương Tháng Trước
            </button>
            <button onclick="exportToExcel()" class="flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-2xl font-bold shadow-lg transition-all active:scale-95">
                <i data-lucide="file-spreadsheet"></i> Xuất Excel
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="relative col-span-2">
            <i data-lucide="search" class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 w-5 h-5"></i>
            <input type="text" id="searchInput" oninput="filterData()" placeholder="Tìm tên sĩ quan hoặc ID..." 
                   class="w-full pl-12 pr-4 py-4 rounded-2xl border-none shadow-sm focus:ring-2 focus:ring-blue-500 outline-none font-medium text-lg">
        </div>
        <div class="relative">
            <i data-lucide="calendar" class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 w-5 h-5"></i>
            <input type="month" id="monthFilter" onchange="filterData()" 
                   class="w-full pl-12 pr-4 py-4 rounded-2xl border-none shadow-sm focus:ring-2 focus:ring-blue-500 outline-none font-medium text-slate-600">
        </div>
    </div>

    <div class="bg-white rounded-[2.5rem] shadow-2xl overflow-hidden border border-slate-200">
      <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-900 text-slate-400 text-[10px] uppercase tracking-[0.2em] font-black">
                <th class="p-8">Tên Sĩ Quan</th>
                <th class="p-8 text-center">Phút ~ Giờ Làm Việc Trong Tháng</th>
                <th class="p-8 text-right">Tổng Lương Tháng	</th>
                <th class="p-8 text-center">Lịch Sử Chấm Công</th>
              </tr>
            </thead>
            <tbody id="mainTableBody" class="divide-y divide-slate-100 font-medium"></tbody>
          </table>
      </div>
    </div>
  </div>

  <div id="historyModal" class="modal p-4">
    <div class="bg-white w-full max-w-4xl rounded-[3rem] shadow-2xl overflow-hidden">
      <div class="bg-slate-900 p-10 text-white flex justify-between items-start">
        <div>
            <h2 id="nameTitle" class="text-3xl font-black italic text-blue-400">---</h2>
            <p class="text-slate-400 flex items-center gap-2"><i data-lucide="clock"></i> Chi tiết chấm công</p>
        </div>
        <button onclick="closeModal('historyModal')" class="bg-white/10 hover:bg-red-500 p-3 rounded-2xl transition-all"><i data-lucide="x"></i></button>
      </div>
      <div class="p-10">
        <div class="grid grid-cols-2 gap-6 mb-8">
            <div class="p-6 bg-blue-50 rounded-3xl border border-blue-100 text-center">
                <p class="text-xs font-black text-blue-600 uppercase">Tổng Giờ</p>
                <p id="statHours" class="text-3xl font-black text-slate-900">0.00h</p>
            </div>
            <div class="p-6 bg-emerald-50 rounded-3xl border border-emerald-100 text-center">
                <p class="text-xs font-black text-emerald-600 uppercase">Lương</p>
                <p id="statSalary" class="text-3xl font-black text-emerald-700">0đ</p>
            </div>
        </div>
        <div class="max-h-[350px] overflow-y-auto custom-scroll border rounded-[2rem]">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 sticky top-0 shadow-sm">
              <tr class="text-slate-400 font-black uppercase text-[10px]">
                <th class="p-4 text-left">Ngày/Tháng/Năm</th>
                <th class="p-4 text-center">Giờ Vào</th>
                <th class="p-4 text-center">Giờ Ra</th>
                <th class="p-4 text-right">Số Giờ</th>
                <th class="p-4 text-center">Action</th>
              </tr>
            </thead>
            <tbody id="historyRows" class="divide-y divide-slate-100 font-bold"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div id="previousPayrollModal" class="modal p-4">
    <div class="bg-white w-full max-w-5xl rounded-[3rem] shadow-2xl overflow-hidden border">
        <div class="bg-blue-900 p-8 text-white flex justify-between items-center">
            <div>
                <h2 class="text-2xl font-black italic uppercase">Bảng Lương Tháng Trước</h2>
                <p class="text-blue-300 text-sm">Đối soát dữ liệu lịch sử</p>
            </div>
            <button onclick="closeModal('previousPayrollModal')" class="bg-white/10 hover:bg-red-500 p-2 rounded-xl transition-all"><i data-lucide="x"></i></button>
        </div>
        <div class="p-8">
            <div id="prevPayrollContent" class="max-h-[500px] overflow-y-auto custom-scroll border rounded-[2rem]"></div>
        </div>
    </div>
  </div>

  <script>
    lucide.createIcons();
    let rawUsers = [];
    try {
        rawUsers = <%- JSON.stringify(users) %>;
    } catch (e) { console.error("Data error:", e); }

    const RATE = 100000;

    function getVal(obj, keys) {
        if(!obj) return null;
        for (let k of keys) {
            if (obj[k] !== undefined && obj[k] !== null && obj[k] !== "") return obj[k];
        }
        return null;
    }

    function filterData() {
        const searchTerm = document.getElementById('searchInput').value.toLowerCase();
        const selectedMonth = document.getElementById('monthFilter').value;
        const tbody = document.getElementById('mainTableBody');

        // BẢN FIX: Giữ nguyên thứ tự gốc, không dùng .sort()
        let filtered = rawUsers.map(user => {
            const history = getVal(user, ['history', 'attendance', 'logs']) || [];
            
            const displayHistory = history.filter(h => {
                if (!selectedMonth) return true;
                const rowDate = (getVal(h, ['date', 'day', 'ngay']) || "").toString();
                const [y, m] = selectedMonth.split('-');
                return rowDate.includes(`${y}-${m}`) || rowDate.includes(`${m}/${y}`) || rowDate.includes(`${m}-${y}`);
            });

            const totalH = displayHistory.reduce((sum, row) => {
                const hVal = getVal(row, ['hours', 'total_time', 'totalTime', 'sogio', 'time']);
                return sum + parseFloat(hVal || 0);
            }, 0);

            return { ...user, displayHistory, totalHours: totalH, totalSalary: totalH * RATE };
        });

        // Chỉ lọc tìm kiếm
        filtered = filtered.filter(u => 
            (u.displayName || "").toLowerCase().includes(searchTerm) || 
            (u.id && u.id.toString().includes(searchTerm))
        );

        tbody.innerHTML = '';
        filtered.forEach(user => {
            tbody.innerHTML += `
              <tr class="hover:bg-slate-50 transition-all border-b">
                <td class="p-8">
                    <div class="font-black text-slate-800 text-lg">${user.displayName || 'N/A'}</div>
                    <div class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1">ID: #${user.id}</div>
                </td>
                <td class="p-8 text-center font-black text-blue-600 font-mono text-lg">${user.totalHours.toFixed(2)}h</td>
                <td class="p-8 text-right font-black text-emerald-600 text-2xl">${Math.floor(user.totalSalary).toLocaleString()}đ</td>
                <td class="p-8 text-center">
                  <button onclick="showHistory('${user.id}')" class="bg-slate-900 hover:bg-blue-600 text-white px-6 py-2 rounded-xl font-black text-[10px] uppercase shadow-lg transition-all active:scale-95">Chi Tiết</button>
                </td>
              </tr>`;
        });
        window.currentFilteredData = filtered;
    }

    function showHistory(userId) {
      const user = window.currentFilteredData.find(u => u.id == userId);
      if (!user) return;
      document.getElementById('nameTitle').innerText = user.displayName;
      const tbody = document.getElementById('historyRows');
      tbody.innerHTML = '';

      user.displayHistory.forEach((row, index) => {
        const hVal = parseFloat(getVal(row, ['hours', 'total_time', 'sogio', 'time']) || 0).toFixed(2);
        tbody.innerHTML += `
          <tr class="hover:bg-slate-50 group">
            <td class="p-4 text-slate-700">${getVal(row, ['date', 'day', 'ngay']) || '-'}</td>
            <td class="p-4 text-center text-blue-600 font-mono font-bold">${getVal(row, ['checkIn', 'checkin', 'vao', 'start']) || '-'}</td>
            <td class="p-4 text-center text-slate-400 font-mono font-bold">${getVal(row, ['checkOut', 'checkout', 'ra', 'end']) || '-'}</td>
            <td class="p-4 text-right text-slate-900 font-black">${hVal}h</td>
            <td class="p-4 text-center">
                <button onclick="deleteRow('${userId}', ${index})" class="text-slate-300 hover:text-red-500 transition-colors focus:outline-none">
                    <i data-lucide="trash-2" class="w-4 h-4"></i>
                </button>
            </td>
          </tr>`;
      });
      document.getElementById('statHours').innerText = user.totalHours.toFixed(2) + 'h';
      document.getElementById('statSalary').innerText = Math.floor(user.totalSalary).toLocaleString() + 'đ';
      document.getElementById('historyModal').classList.add('active');
      lucide.createIcons();
    }

    function deleteRow(userId, index) {
        if(!confirm("Xóa ngày công này? Hệ thống sẽ cập nhật lại lương ngay.")) return;
        const uIdx = rawUsers.findIndex(u => u.id == userId);
        if(uIdx === -1) return;
        
        const key = rawUsers[uIdx].history ? 'history' : (rawUsers[uIdx].attendance ? 'attendance' : 'logs');
        rawUsers[uIdx][key].splice(index, 1);
        
        filterData();
        showHistory(userId);
    }

    function openPreviousMonth() {
        const content = document.getElementById('prevPayrollContent');
        const now = new Date();
        now.setMonth(now.getMonth() - 1);
        const prevMonthStr = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
        const label = `${now.getMonth() + 1}/${now.getFullYear()}`;

        let prevData = rawUsers.map(user => {
            const h = getVal(user, ['history', 'attendance', 'logs']) || [];
            const filteredH = h.filter(r => {
                const d = (getVal(r, ['date', 'day', 'ngay']) || "").toString();
                return d.includes(prevMonthStr) || d.includes(`${String(now.getMonth() + 1).padStart(2, '0')}/${now.getFullYear()}`);
            });
            const totalH = filteredH.reduce((s, r) => s + parseFloat(getVal(r, ['hours', 'total_time', 'sogio']) || 0), 0);
            return { ...user, totalH, totalS: totalH * RATE };
        }).filter(u => u.totalH > 0); // Giữ nguyên thứ tự gốc ở đây luôn

        let html = `<table class="w-full text-left"><thead class="bg-slate-50 sticky top-0"><tr class="text-[10px] font-black p-4 border-b">
                <th class="p-4">Họ Tên</th><th class="p-4 text-center">Giờ (${label})</th><th class="p-4 text-right">Lương</th>
            </tr></thead><tbody class="divide-y">`;
        
        prevData.forEach(u => {
            html += `<tr class="hover:bg-blue-50/50"><td class="p-4 font-bold text-slate-700">${u.displayName}</td>
                <td class="p-4 text-center font-black text-blue-600">${u.totalH.toFixed(2)}h</td>
                <td class="p-4 text-right font-black text-emerald-600">${Math.floor(u.totalS).toLocaleString()}đ</td></tr>`;
        });
        content.innerHTML = prevData.length ? html + `</tbody></table>` : `<div class="p-20 text-center font-bold text-slate-300">Không có dữ liệu tháng ${label}</div>`;
        document.getElementById('previousPayrollModal').classList.add('active');
        lucide.createIcons();
    }

    function closeModal(id) { document.getElementById(id).classList.remove('active'); }
    
    function exportToExcel() {
        const data = window.currentFilteredData || [];
        const ws = XLSX.utils.json_to_sheet(data.map(u => ({ "Tên": u.displayName, "ID": u.id, "Tổng Giờ": u.totalHours.toFixed(2), "Lương": Math.floor(u.totalSalary) })));
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Payroll");
        XLSX.writeFile(wb, "BangLuong.xlsx");
    }

    filterData();
  </script>
</body>
</html>