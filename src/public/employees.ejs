<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản Lý Nhân Viên & Lương</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      color: #1f2937;
    }
    .glass {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.3);
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }
  </style>
</head>
<body class="antialiased">
  <div class="container mx-auto px-4 py-8 max-w-6xl">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white drop-shadow-lg flex items-center justify-center gap-4">
        <i data-lucide="users" class="w-12 h-12"></i>
        QUẢN LÝ NHÂN VIÊN
      </h1>
      <p class="text-xl text-white/90 mt-3">
        Chào <span class="font-bold text-yellow-300"><%= currentUser?.displayName || 'Admin' %></span> 👋
      </p>
      <p class="text-lg text-white/80 mt-1">
        <%= new Date().toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
      </p>
    </div>

    <!-- Nút xuất Excel (giữ nếu bạn cần) -->
    <div class="text-center mb-8">
      <a href="/export-salary-excel" 
         class="inline-flex items-center gap-3 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-bold text-xl py-4 px-10 rounded-full shadow-xl transform hover:scale-105 transition">
        <i data-lucide="file-spreadsheet" class="w-8 h-8"></i>
        Xuất Excel Lương Toàn Bộ
      </a>
    </div>

    <!-- Bảng nhân viên -->
    <div class="glass rounded-2xl overflow-hidden">
      <div class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white p-6 text-center">
        <h2 class="text-3xl font-bold">DANH SÁCH NHÂN VIÊN</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left">
          <thead class="bg-gray-100">
            <tr>
              <th class="px-6 py-4 font-semibold text-gray-700">ID</th>
              <th class="px-6 py-4 font-semibold text-gray-700">Họ tên</th>
              <th class="px-6 py-4 font-semibold text-gray-700">Chức vụ</th>
              <th class="px-6 py-4 text-center font-semibold text-gray-700">Hành động</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <% users.forEach(user => { %>
              <tr class="hover:bg-indigo-50 transition">
                <td class="px-6 py-5 font-medium text-indigo-800">#<%= user.id || user._id %></td>
                <td class="px-6 py-5 font-semibold"><%= user.displayName || 'N/A' %></td>
                <td class="px-6 py-5 text-gray-700"><%= user.position || 'Chưa cập nhật' %> <%= user.rank || '' %></td>
                <td class="px-6 py-5 text-center">
                  <button 
                    onclick="openHistory('<%= user._id || user.id %>', '<%= user.displayName %>')"
                    class="bg-indigo-500 hover:bg-indigo-600 text-white px-6 py-3 rounded-lg font-medium shadow transition transform hover:scale-105">
                    <i data-lucide="clock" class="w-5 h-5 inline mr-2"></i>
                    Xem lịch sử & lương
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Footer -->
    <div class="text-center mt-10 text-white text-lg">
      <a href="/home" class="hover:underline mr-8 font-medium">← Về Trang Chủ</a>
      <a href="/logout" onclick="return confirm('Đăng xuất?')" class="text-red-300 hover:text-red-200 font-medium">Đăng Xuất</a>
    </div>
  </div>

  <!-- Modal đơn giản -->
  <div id="historyModal" class="fixed inset-0 bg-black/70 hidden flex items-center justify-center z-50 px-4">
    <div class="glass rounded-2xl w-full max-w-4xl max-h-[90vh] overflow-hidden shadow-2xl">
      <div class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white p-6 flex justify-between items-center">
        <h3 id="modalTitle" class="text-2xl font-bold">Lịch sử chấm công</h3>
        <button onclick="closeModal()" class="hover:bg-white/20 p-2 rounded-full transition">
          <i data-lucide="x" class="w-8 h-8"></i>
        </button>
      </div>
      <div id="modalContent" class="p-6 overflow-y-auto max-h-[60vh]">
        <div class="text-center py-12">
          <i data-lucide="loader-2" class="w-12 h-12 animate-spin text-indigo-600 mx-auto"></i>
          <p class="mt-4 text-lg text-gray-600">Đang tải lịch sử...</p>
        </div>
      </div>
      <div class="bg-gray-50 p-6 text-center border-t">
        <p class="text-xl font-bold text-gray-800">TỔNG LƯƠNG</p>
        <p id="totalSalary" class="text-5xl font-black text-indigo-700 mt-2">$0</p>
      </div>
    </div>
  </div>

  <script>
    lucide.createIcons();

    function openHistory(userId, name) {
      const modal = document.getElementById('historyModal');
      const title = document.getElementById('modalTitle');
      const content = document.getElementById('modalContent');
      const salaryEl = document.getElementById('totalSalary');

      if (!modal || !title || !content || !salaryEl) {
        alert('Lỗi: Không tìm thấy modal trong DOM');
        return;
      }

      title.textContent = `Lịch sử - ${name || 'Nhân viên'}`;
      content.innerHTML = `
        <div class="text-center py-12">
          <i data-lucide="loader-2" class="w-12 h-12 animate-spin text-indigo-600 mx-auto"></i>
          <p class="mt-4 text-lg text-gray-600">Đang tải...</p>
        </div>`;
      salaryEl.textContent = '$0';
      modal.classList.remove('hidden');
      lucide.createIcons();

      // Fetch với timeout
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 10000);

      fetch(`/admin/history/${userId}`, { signal: controller.signal })
        .then(r => {
          clearTimeout(timeoutId);
          if (!r.ok) throw new Error(`Lỗi ${r.status}`);
          return r.json();
        })
        .then(data => {
          let html = '';
          let total = 0;
          const history = data.history || [];

          if (history.length > 0) {
            history.forEach(item => {
              total += item.salary || 0;
              html += `
                <div class="bg-white p-5 rounded-xl shadow mb-4 border border-gray-200">
                  <div class="flex justify-between items-start">
                    <div>
                      <div class="text-xl font-bold text-indigo-800">${item.date || 'N/A'}</div>
                      <div class="text-gray-600 mt-1">
                        Vào: ${item.onTime || '-'} → Ra: ${item.offTime || 'Chưa off'}
                      </div>
                    </div>
                    <div class="text-right">
                      <div class="text-3xl font-bold text-green-600">+$${(item.salary || 0).toLocaleString()}</div>
                      <div class="text-gray-500">${(item.hours || 0).toFixed(2)} giờ</div>
                    </div>
                  </div>
                </div>`;
            });
          } else {
            html = `
              <div class="text-center py-16 text-gray-500">
                <i data-lucide="calendar-x" class="w-20 h-20 mx-auto opacity-50"></i>
                <p class="mt-4 text-xl">Chưa có dữ liệu chấm công</p>
              </div>`;
          }

          content.innerHTML = html;
          salaryEl.textContent = '$' + total.toLocaleString();
          lucide.createIcons();
        })
        .catch(err => {
          content.innerHTML = `
            <div class="text-center py-12 text-red-600">
              <i data-lucide="alert-triangle" class="w-12 h-12 mx-auto"></i>
              <p class="mt-4 text-xl font-medium">Lỗi tải dữ liệu: ${err.name === 'AbortError' ? 'Timeout' : err.message}</p>
            </div>`;
        });
    }

    function closeModal() {
      const modal = document.getElementById('historyModal');
      if (modal) modal.classList.add('hidden');
    }

    // Optional: Đóng modal khi click ngoài
    document.getElementById('historyModal')?.addEventListener('click', e => {
      if (e.target === document.getElementById('historyModal')) closeModal();
    });
  </script>
</body>
</html>