<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nhân Sự</title>
    <link rel="icon" type="image/x-icon" href="/images/Logo_DOC.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    
    <style>
        :root { --primary: #1a4720; }
        body { background: linear-gradient(135deg, #f8fafc 0%, #e0f2fe 100%); }
        .main-header, .navbar-custom { background: linear-gradient(90deg, #838fb4, #112522) !important; }
        .modal-content { border-radius: 20px; box-shadow: 0 25px 50px rgba(0,0,0,0.3); }
        .btn-action-hr { border-radius: 50px; font-weight: 600; padding: 10px 20px; }
        .btn-add { background: linear-gradient(135deg, #445381, #3b82f6); color: white; border: none; }
        .table th { background: var(--primary); color: white; }
        .permission-badge { font-size: 0.85rem; padding: 4px 10px; border-radius: 20px; }
    </style>
</head>
<body>

<!-- Header -->
<header class="main-header">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center">
            <div class="nav-logo">
                <h5 class="lilita-one-regular"></h5>
            </div>
            <div class="user-info d-flex align-items-center gap-3">
                <span style="font-size: 1.1rem; color: #fff; font-weight: 700;">Admin</span>
                <img src="https://ui-avatars.com/api/?name=Admin&background=1e40af&color=fff&bold=true&rounded=true" 
                     class="rounded-circle" width="50" height="50" style="border: 3px solid white;">
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle" data-bs-toggle="dropdown">
                        <i class="fa-solid fa-caret-down"></i>
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="/profile">Hồ sơ</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger" href="/logout">Đăng xuất</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-custom navbar-dark">
    <div class="container">
        <a class="navbar-brand" href="/home">
            <img src="/images/Logo_DOC.png" alt="Logo" height="50">
        </a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav">
                <li class="nav-item"><a class="nav-link" href="/home">Trang Chủ</a></li>
                <li class="nav-item"><a class="nav-link" href="/attendance">Chấm Công</a></li>
                <li class="nav-item dropdown">
                    <a class="nav-link active dropdown-toggle" data-bs-toggle="dropdown">Quản Lý</a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item active" href="/admin">Quản Lý Thành Viên</a></li>
                    </ul>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-4">

    <% if (success) { %>
        <div class="alert alert-success text-center"><%= success %></div>
    <% } %>
    <% if (error) { %>
        <div class="alert alert-danger text-center"><%= error %></div>
    <% } %>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="col-md-6">
            <input type="text" id="search-employee" class="form-control" placeholder="Tìm tên sĩ quan hoặc username...">
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-action-hr" data-bs-toggle="modal" data-bs-target="#trashModal">
                <i class="fa-solid fa-trash-can"></i> Thùng Rác
            </button>
            <button class="btn btn-primary btn-action-hr btn-add" data-bs-toggle="modal" data-bs-target="#createUserModal">
                <i class="fa-solid fa-circle-plus"></i> Tạo Nhân Sự
            </button>
        </div>
    </div>

    <!-- Bảng Nhân Sự -->
    <div class="card shadow">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle text-center">
                    <thead class="table-primary">
                        <tr>
                            <th>STT</th>
                            <th>AVT</th>
                            <th>Tên Sĩ Quan</th>
                            <th>Username</th>
                            <th>Chức Vụ</th>
                            <th>Quân Hàm</th>
                            <th>Quyền</th>
                            <th>ID Discord</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody id="userTableBody">
                        <% db.users.forEach((user, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td>
                                <img src="<%= user.avatar || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.displayName || user.username) + '&background=1e40af&color=fff&bold=true&rounded=true' %>" 
                                     class="rounded-circle" width="50" height="50" style="object-fit: cover;">
                            </td>
                            <td><strong><%= user.displayName || 'Chưa đặt' %></strong></td>
                            <td><%= user.username %></td>
                            <td><%= user.rank || '-' %></td>
                            <td><%= user.position || '-' %></td>
                            <td>
                                <span class="permission-badge <%= user.role === 'admin' ? 'bg-danger' : 'bg-success' %> text-white">
                                    <%= user.role === 'admin' ? 'Admin' : 'User' %>
                                </span>
                            </td>
                            <td><%= user.discordId || 'Chưa liên kết' %></td>
                            <td>
                                <button class="btn btn-sm btn-warning me-1" onclick="openPermissionModal('<%= user.id %>', '<%= user.username %>', '<%= user.role %>')">
                                    <i class="fa-solid fa-key"></i>
                                </button>
                                <form method="POST" action="/admin/delete/<%= user.id %>" class="d-inline" onsubmit="return confirm('Xóa thật?')">
                                    <button type="submit" class="btn btn-danger btn-sm"><i class="fa-solid fa-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ==================== MODAL TẠO NHÂN SỰ (ĐÃ KHÔI PHỤC) ==================== -->
<div class="modal fade" id="createUserModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fa-solid fa-user-plus"></i> Tạo Nhân Sự Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="POST" action="/admin/create-user" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="row g-4">
                        <div class="col-md-4 text-center">
                            <img id="avatarPreview" src="/assets/images/user_preview_logo.png" class="rounded-circle" width="160" height="160" style="object-fit: cover; border: 4px solid #ddd;">
                            <input type="file" id="avatarInput" name="avatar" hidden accept="image/*" onchange="previewImage(event)">
                            <button type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="document.getElementById('avatarInput').click()">Chọn ảnh</button>
                        </div>
                        <div class="col-md-8">
                            <div class="row g-3">
                                <div class="col-12"><input type="text" name="displayName" class="form-control" placeholder="Tên hiển thị" required></div>
                                <div class="col-md-6"><input type="text" name="username" class="form-control" placeholder="Username" required></div>
                                <div class="col-md-6"><input type="password" name="password" class="form-control" placeholder="Mật khẩu" required></div>
                                <div class="col-md-6">
                                    <select name="rank" class="form-select" required>
                                        <option value="">Chọn chức vụ...</option>
                                        <% positions.forEach(p => { %><option value="<%= p %>"><%= p %></option><% }) %>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <select name="position" class="form-select">
                                        <option value="">Quân hàm (tùy chọn)</option>
                                        <% ranks.forEach(r => { %><option value="<%= r %>"><%= r %></option><% }) %>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Tạo Nhân Sự</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Chỉnh Quyền -->
<div class="modal fade" id="permissionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title">Chỉnh Quyền Người Dùng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="POST" action="/admin/update-role">
                <input type="hidden" name="userId" id="permUserId">
                <div class="modal-body">
                    <p><strong>Người dùng:</strong> <span id="permUsername" class="fw-bold"></span></p>
                    <select name="role" id="permRole" class="form-select">
                        <option value="user">User</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
function previewImage(event) {
    const reader = new FileReader();
    reader.onload = () => document.getElementById('avatarPreview').src = reader.result;
    reader.readAsDataURL(event.target.files[0]);
}

function openPermissionModal(userId, username, currentRole) {
    document.getElementById('permUserId').value = userId;
    document.getElementById('permUsername').textContent = username;
    document.getElementById('permRole').value = currentRole || 'user';
    new bootstrap.Modal(document.getElementById('permissionModal')).show();
}

// Tìm kiếm
document.getElementById('search-employee').addEventListener('keyup', function() {
    const filter = this.value.toLowerCase();
    document.querySelectorAll('#userTableBody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
    });
});
</script>
</body>
</html>